# ============================================================
# RUMA Environment Configuration
# Copy to .env for local dev. NEVER commit .env to git.
# ============================================================

# ── REQUIRED: CoinMarketCap AI Agent Hub ──────────────────────────────────────
CMC_API_KEY=YOUR_CMC_API_KEY_HERE
CMC_MCP_ENDPOINT=https://mcp.coinmarketcap.com
CMC_X402_ENABLED=true

# ── REQUIRED: Trust Wallet Agent Kit (TWAK) ───────────────────────────────────
TWAK_AGENT_PRIVATE_KEY=0x_YOUR_AGENT_PRIVATE_KEY_HERE
TWAK_ENDPOINT=https://api.trustwallet.com/agent/v1
TWAK_AUTONOMOUS_MODE=true

# ── REQUIRED: BNB Chain ───────────────────────────────────────────────────────
BSC_NETWORK=testnet
BSC_RPC_MAINNET=https://bsc-dataseed.binance.org
BSC_RPC_TESTNET=https://data-seed-prebsc-1-s1.binance.org:8545
BNB_COMPETITION_CONTRACT=0x212c61b9b72c95d95bf29cf032f5e5635629aed5
AGENT_OPERATOR_ADDRESS=0x_YOUR_AGENT_ADDRESS_HERE

# ── REQUIRED: Trading ─────────────────────────────────────────────────────────
TRADING_ENABLED=true
MAX_DRAWDOWN_PCT=30
DAILY_LOSS_LIMIT_PCT=6
MAX_POSITION_PCT=2

# ── OPTIONAL: AI Reasoning ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# ── OPTIONAL: Database ────────────────────────────────────────────────────────
DATABASE_URL=

# ── OPTIONAL: BNB AI Agent SDK ────────────────────────────────────────────────
BNB_AGENT_SDK_ENDPOINT=https://api.bnbagent.xyz

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000
SESSION_SECRET=change_me_in_production

# ── Telegram Alerts ───────────────────────────────────────────────────────────
# Fires when Ψ-gate opens and a trade executes, drawdown hit, Λ milestones, etc.
# Get your bot token from @BotFather on Telegram.
# Get your chat ID: message @userinfobot or @getidsbot in your channel.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALERTS_ENABLED=true
# Optional: for Telegram forum/topic threads
TELEGRAM_THREAD_ID=
